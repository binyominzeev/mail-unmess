{
  "manifest_version": 3,
  "name": "mail-unmess",
  "version": "1.0.0",
  "description": "Gmail browser extension for instant CRM experience — manage email threads as simple tickets.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
